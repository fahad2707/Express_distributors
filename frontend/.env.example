# Public API base (no secrets), must end up as .../api . Example: https://YOUR-SERVICE.onrender.com/api
#
# Vercel (recommended): set this on the project and redeploy. The browser then calls your API
# directly (Bearer auth works reliably). Also used for /site inject-site-api.cjs at build.
# If you omit it, the app falls back to same-origin /api and you must set BACKEND_URL for the proxy.
NEXT_PUBLIC_API_URL=http://localhost:5001/api
# Vercel server-side /api proxy (not sent to the browser). Example: https://YOUR-SERVICE.onrender.com
# BACKEND_URL=

# Stripe publishable key only (safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
