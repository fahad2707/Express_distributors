# Public URL of the API (no secrets). Example for production: https://YOUR-SERVICE.onrender.com/api
# Vercel: set this so the /site storefront can load products (baked in at build via scripts/inject-site-api.cjs).
# Alternatively use same-origin /api and set BACKEND_URL on Vercel (no NEXT_PUBLIC) — see Vercel env docs.
NEXT_PUBLIC_API_URL=http://localhost:5001/api
# Vercel server-side proxy only (not exposed to the browser). Example: https://YOUR-SERVICE.onrender.com
# BACKEND_URL=

# Stripe publishable key only (safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
