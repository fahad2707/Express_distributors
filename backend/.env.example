PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/express_distributors

# Generate: openssl rand -hex 32
JWT_SECRET=
# Shorter lived sessions in production (e.g. 8h). Admins may use longer via env.
JWT_EXPIRES_IN=8h

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=express-distributors

# Create default admin@edinc.com only when NODE_ENV is not production
# ALLOW_DEFAULT_ADMIN=false
