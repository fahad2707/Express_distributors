PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/express_distributors

# Railway / Atlas: name must be exactly MONGODB_DB_NAME (not "mongo db name" or MONGO_DB_NAME).
# If Compass shows data under database "test", set:
# MONGODB_DB_NAME=test
# Then run the XLS import once with the SAME MONGODB_URI + MONGODB_DB_NAME or the site will be empty.

# Generate: openssl rand -hex 32
JWT_SECRET=
# Shorter lived sessions in production (e.g. 8h). Admins may use longer via env.
JWT_EXPIRES_IN=8h

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=express-distributors

# Create default admin@edinc.com only when NODE_ENV is not production
# ALLOW_DEFAULT_ADMIN=false
